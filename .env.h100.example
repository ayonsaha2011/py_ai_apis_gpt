HF_TOKEN=replace-with-huggingface-token
HF_HOME=/mnt/models/.cache/huggingface
MODEL_MIN_FREE_GB=120
HF_HUB_DOWNLOAD_THREADS=4

GATEWAY_BIND=0.0.0.0:8080
GATEWAY_PROFILE=cloud_h100
RUNTIME_BACKEND=native
COMPOSE_PROJECT=py_ai_apis_gpt_h100
SERVICE_LOG_DIR=runtime/h100/logs
CORS_PERMISSIVE=false
CORS_ALLOWED_ORIGINS=https://your-console.example.com

ADMIN_API_KEY=replace-with-long-admin-key
ADMIN_EMAILS=
SERVICE_API_KEY=replace-with-long-service-key
SESSION_TTL_SECONDS=86400

TURSO_DB_URL=libsql://replace-with-database-url
TURSO_AUTH_TOKEN=replace-with-turso-token

TEXT_WORKER_URL=http://127.0.0.1:8101
LTX_WORKER_URL=http://127.0.0.1:8102

TEXT_MODEL_ID=google/gemma-3-12b-it-qat-q4_0-unquantized
TEXT_MODEL_DIR=models/text/gemma-3-12b-it-qat-q4_0-unquantized
TEXT_MODEL_REGISTRY=google/gemma-3-12b-it-qat-q4_0-unquantized
# Keep the text model on GPU. Single-H100 full LTX + Gemma co-residency is not supported;
# use cuda:1 or another GPU host for text when LTX owns cuda:0.
TEXT_DEVICE=cuda:1
TEXT_MAX_WAITING=512
TEXT_MAX_ACTIVE=64
TEXT_MAX_BATCH_TOKENS=8192
TEXT_KV_CACHE_BYTES=34359738368

LTX_MODEL_DIR=models/ltx-2.3
LTX_GEMMA_ROOT=models/text/gemma-3-12b-it-qat-q4_0-unquantized
LTX_GIT_REF=41d924371612b692c0fd1e4d9d94c3dfb3c02cb3
LTX_CUDA_DEVICE=cuda:0
LTX_QUANTIZATION=none
LTX_TORCH_COMPILE=false
LTX_PRELOAD_ON_START=true
LTX_CLEAR_PIPELINE_ON_OOM=false
LTX_MAX_WAITING=512
LTX_LOCAL_MAX_HEAVY_JOBS=1
LTX_MAX_TOKENS_H100=540000
LTX_MAX_NUM_FRAMES=481
TEXT_HEAVY_JOBS=1
VIDEO_HEAVY_JOBS=1

LOCAL_STORAGE_DIR=storage
FRONTEND_DIR=frontend/dist

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_MANAGED=native
QDRANT_VERSION=1.11.0
QDRANT_BIN=/opt/qdrant/qdrant
QDRANT_STORAGE=storage/qdrant

R2_ACCOUNT_ID=replace-with-r2-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=replace-with-r2-bucket
R2_PUBLIC_BASE_URL=https://replace-with-r2-public-host


# Base interpreter used to create .venv-h100 with --system-site-packages.
# This preserves preinstalled CUDA PyTorch, for example torch 2.8.0+cu128.
AI_PYTHON_BIN=python3.12
